# Server Configuration
HOST=0.0.0.0
PORT=8000

# Gemini API (REQUIRED)
GEMINI_API_KEY=api_key(original_one_deprecated)
GEMINI_PROJECT=project_id(original_one_deprecated)
GEMINI_LOCATION=location(original_one_deprecated)
GEMINI_MODEL=model(original_one_deprecated)

# Ollama (for local embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text



# CORS
CORS_ORIGINS=["*"]

# PostgreSQL/pgvector Configuration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=eduquestdb
PG_USER=eduquestuser
PG_PASSWORD=eduquestpass

# Logging
LOG_LEVEL=INFO
